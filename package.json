{
  "name": "ai-execution-firewall",
  "version": "1.0.6",
  "description": "A firewall that blocks dangerous AI requests before they execute",
  "main": "dist/index.js",
  "bin": {
    "aifw": "dist/cli/index.js",
    "ai-execution-firewall": "dist/bin/start.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js start",
    "dev": "ts-node src/cli/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageThreshold='{\"global\":{\"branches\":70,\"functions\":70,\"lines\":70,\"statements\":70}}'",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "preflight": "node scripts/preflight.js",
    "ci": "npm run preflight && npm run lint",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "ai",
    "firewall",
    "protection",
    "openai",
    "anthropic",
    "agent-safety",
    "api-security"
  ],
  "author": "Salim Assili",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/salimassili62-afk/ai-waste-guard.git"
  },
  "bugs": {
    "url": "https://github.com/salimassili62-afk/ai-waste-guard/issues"
  },
  "homepage": "https://github.com/salimassili62-afk/ai-waste-guard#readme",
  "dependencies": {
    "axios": "^1.6.2",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "express": "^4.18.2",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^30.3.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "directories": {
    "example": "examples"
  },
  "type": "commonjs",
  "types": "./dist/index.d.ts"
}
