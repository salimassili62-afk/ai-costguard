{
  "name": "@salimassili/ai-costguard",
  "version": "1.2.0",
  "description": "AI Agent Loop & Cost Firewall. Detects infinite loops in autonomous AI agents and kills them before they burn your API budget.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc",
    "test": "node --experimental-vm-modules test/smoke.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "openai",
    "llm",
    "cost-control",
    "agent",
    "firewall"
  ],
  "author": "Salim Assili",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "rimraf": "^5.0.10",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "ioredis": "^5.10.1"
  }
}
